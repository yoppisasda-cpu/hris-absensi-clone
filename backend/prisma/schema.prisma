generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id                     Int                  @id @default(autoincrement())
  name                   String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  latitude               Float?
  longitude              Float?
  radius                 Int?                 @default(100)
  absenceDeductionRate   Float                @default(0)
  absenceDeductionType   AbsenceDeductionType @default(PRO_RATA)
  integrationApiKey      String?              @unique
  lateDeductionRate      Float                @default(50000)
  sickLeaveDeductionRate Float                @default(0)
  contractEnd            DateTime?
  contractStart          DateTime?
  contractType           ContractType         @default(LUMSUM)
  contractValue          Float                @default(0)
  picName                String?
  picPhone               String?
  employeeLimit          Int                  @default(0)
  photoRetentionDays     Int                  @default(30)
  workDaysPerMonth       Int                  @default(25)
  lateGracePeriod        Int                  @default(0)
  modules                AppModule            @default(ABSENSI)
  purchasedInsights      String[]             @default([])
  crmEnabled             Boolean              @default(true)
  address                String?
  logoUrl                String?
  announcements          Announcement[]
  assets                 Asset[]
  attendances            Attendance[]
  bonuses                Bonus[]
  branches               Branch[]
  documents              EmployeeDocument[]
  employeeVents          EmployeeVent[]
  exams                  Exam[]
  examAttempts           ExamAttempt[]
  expenses               Expense[]
  expenseCategories      ExpenseCategory[]
  financialAccounts      FinancialAccount[]
  holidays               Holiday[]
  incomes                Income[]
  incomeCategories       IncomeCategory[]
  invoices               Invoice[]
  kpiIndicators          KPIIndicator[]
  kpiScores              KPIScore[]
  knowledgeReviews       KnowledgeReview[]
  learningMaterials      LearningMaterial[]
  learningObjectives     LearningObjective[]
  leaveRequests          LeaveRequest[]
  loans                  Loan[]
  notifications          Notification[]
  overtimeRequests       OvertimeRequest[]
  payrolls               Payroll[]
  Product                Product[]
  reimbursements         Reimbursement[]
  shifts                 Shift[]
  users                  User[]
  periodClosings         PeriodClosing[]
  warehouses             Warehouse[]
}

model FinancialAccount {
  id        Int       @id @default(autoincrement())
  companyId Int
  name      String
  type      String
  balance   Float     @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  incomes   Income[]
}

model IncomeCategory {
  id        Int      @id @default(autoincrement())
  companyId Int
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  incomes   Income[]
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Income {
  id           Int              @id @default(autoincrement())
  companyId    Int
  accountId    Int
  categoryId   Int
  amount       Float
  date         DateTime         @default(now())
  description  String?
  receivedFrom String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  account      FinancialAccount @relation(fields: [accountId], references: [id])
  category     IncomeCategory   @relation(fields: [categoryId], references: [id])
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, date])
}

model ExpenseCategory {
  id        Int         @id @default(autoincrement())
  companyId Int
  name      String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  type      ExpenseType @default(OPERATIONAL)
  expenses  Expense[]
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Expense {
  id          Int               @id @default(autoincrement())
  companyId   Int
  accountId   Int?
  categoryId  Int
  amount      Float
  date        DateTime          @default(now())
  description String?
  paidTo      String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  dueDate     DateTime?
  status      ExpenseStatus     @default(PAID)
  supplierId  Int?
  account     FinancialAccount? @relation(fields: [accountId], references: [id])
  category    ExpenseCategory   @relation(fields: [categoryId], references: [id])
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier    Supplier?         @relation(fields: [supplierId], references: [id], onUpdate: NoAction)

  @@index([companyId, date])
}

model Supplier {
  id            Int       @id @default(autoincrement())
  companyId     Int
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  category      String?
  createdAt     DateTime  @default(now()) @db.Timestamp(6)
  updatedAt     DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  expenses      Expense[]
}

model Branch {
  id        Int      @id @default(autoincrement())
  companyId Int
  name      String
  latitude  Float?
  longitude Float?
  radius    Int?     @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users     User[]
}

model User {
  id                      Int                 @id @default(autoincrement())
  companyId               Int
  email                   String              @unique
  password                String
  name                    String
  role                    Role                @default(EMPLOYEE)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  basicSalary             Float               @default(0)
  shiftId                 Int?
  allowance               Float               @default(0)
  branchId                Int?
  division                String?
  emailNotifications      Boolean             @default(true)
  grade                   String?
  jobTitle                String?
  joinDate                DateTime?
  overtimeRate            Float               @default(0)
  bpjsKesehatan           Boolean             @default(false)
  bpjsKetenagakerjaan     Boolean             @default(false)
  contractEndDate         DateTime?
  taxStatus               String              @default("TK-0")
  language                String              @default("id")
  faceReferenceUrl        String?
  isActive                Boolean             @default(true)
  reportToId              Int?
  resignDate              DateTime?
  lastDeviceId            String?
  assets                  Asset[]
  attendances             Attendance[]
  bonuses                 Bonus[]
  chatSessions            ChatSession[]
  documents               EmployeeDocument[]
  employeeVents           EmployeeVent[]
  examAttempts            ExamAttempt[]
  kpiScores               KPIScore[]
  knowledgeReviews        KnowledgeReview[]
  learningObjectives      LearningObjective[]
  managedLeaveRequests    LeaveRequest[]      @relation("LeaveApprover")
  leaveRequests           LeaveRequest[]
  loans                   Loan[]
  notifications           Notification[]
  managedOvertimeRequests OvertimeRequest[]   @relation("OvertimeApprover")
  overtimeRequests        OvertimeRequest[]
  payrolls                Payroll[]
  reimbursements          Reimbursement[]
  branch                  Branch?             @relation(fields: [branchId], references: [id])
  company                 Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reportTo                User?               @relation("ReportingLine", fields: [reportToId], references: [id])
  subordinates            User[]              @relation("ReportingLine")
  shift                   Shift?              @relation(fields: [shiftId], references: [id])
}

model OvertimeRequest {
  id            Int            @id @default(autoincrement())
  companyId     Int
  userId        Int
  date          DateTime
  durationHours Float
  reason        String
  status        OvertimeStatus @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  approverId    Int?
  approver      User?          @relation("OvertimeApprover", fields: [approverId], references: [id])
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Shift {
  id        Int      @id @default(autoincrement())
  companyId Int
  title     String
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users     User[]
}

model Attendance {
  id                  Int              @id @default(autoincrement())
  companyId           Int
  userId              Int
  clockIn             DateTime         @default(now())
  clockOut            DateTime?
  lat                 Float?
  lng                 Float?
  photoUrl            String?
  status              AttendanceStatus @default(PRESENT)
  mood                String?
  moodScore           Float?
  clockOutLat         Float?
  clockOutLng         Float?
  clockOutPhotoUrl    String?
  faceSimilarityScore Float?
  isFaceVerified      Boolean          @default(false)
  fraudScore          Float?
  isSuspicious        Boolean          @default(false)
  deviceId            String?
  company             Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, clockIn])
}

model LeaveRequest {
  id         Int         @id @default(autoincrement())
  companyId  Int
  userId     Int
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     LeaveStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  type       LeaveType   @default(ANNUAL)
  approverId Int?
  approver   User?       @relation("LeaveApprover", fields: [approverId], references: [id])
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payroll {
  id                           Int          @id @default(autoincrement())
  companyId                    Int
  userId                       Int
  month                        Int
  year                         Int
  basicSalary                  Float
  attendanceCount              Int
  lateCount                    Int
  deductions                   Float
  netSalary                    Float
  status                       SalaryStatus @default(DRAFT)
  createdAt                    DateTime     @default(now())
  updatedAt                    DateTime     @updatedAt
  allowance                    Float        @default(0)
  loanDeduction                Float        @default(0)
  overtimeHours                Float        @default(0)
  overtimePay                  Float        @default(0)
  bpjsKesehatanDeduction       Float        @default(0)
  bpjsKetenagakerjaanDeduction Float        @default(0)
  pph21Deduction               Float        @default(0)
  bpjsCompanyContribution      Float        @default(0)
  sickLeaveCount               Int          @default(0)
  sickLeaveDeduction           Float        @default(0)
  reimbursementPay             Float        @default(0)
  bonusPay                     Float        @default(0)
  company                      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

model Loan {
  id               Int        @id @default(autoincrement())
  companyId        Int
  userId           Int
  amount           Float
  monthlyDeduction Float
  remainingAmount  Float
  status           LoanStatus @default(PENDING)
  description      String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  company          Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reimbursement {
  id          Int                 @id @default(autoincrement())
  companyId   Int
  userId      Int
  title       String
  description String?
  amount      Float
  receiptUrl  String?
  status      ReimbursementStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  fraudReason String?
  isFraud     Boolean             @default(false)
  ocrAmount   Float?
  ocrCategory String?
  ocrDate     DateTime?
  receiptHash String?
  isPaid      Boolean             @default(false)
  paidAt      DateTime?
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Holiday {
  id        Int       @id @default(autoincrement())
  companyId Int
  date      DateTime
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  endDate   DateTime?
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
}

model Announcement {
  id         Int      @id @default(autoincrement())
  companyId  Int
  title      String
  content    String
  isPriority Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  imageUrl   String?
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmployeeDocument {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  title     String
  fileUrl   String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id           Int       @id @default(autoincrement())
  companyId    Int
  userId       Int?
  name         String
  serialNumber String
  condition    String    @default("GOOD")
  purchaseDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  imageUrl     String?
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User?     @relation(fields: [userId], references: [id])

  @@unique([companyId, serialNumber])
}

model Bonus {
  id          Int      @id @default(autoincrement())
  companyId   Int
  userId      Int
  type        String
  amount      Float
  description String?
  month       Int
  year        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KPIIndicator {
  id          Int        @id @default(autoincrement())
  companyId   Int
  name        String
  description String?
  target      Float      @default(100)
  weight      Float      @default(1)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  isSystem    Boolean    @default(false)
  systemType  String?
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  scores      KPIScore[]
}

model KPIScore {
  id                  Int                @id @default(autoincrement())
  companyId           Int
  userId              Int
  indicatorId         Int
  score               Float
  comment             String?
  month               Int
  year                Int
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  learningObjectiveId Int?
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  indicator           KPIIndicator       @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  learningObjective   LearningObjective? @relation(fields: [learningObjectiveId], references: [id])
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, indicatorId, month, year])
}

model EmployeeVent {
  id          Int      @id @default(autoincrement())
  companyId   Int
  userId      Int?
  content     String
  isAnonymous Boolean  @default(false)
  sentiment   String?
  mood        String?
  score       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])
}

model LearningObjective {
  id          Int               @id @default(autoincrement())
  companyId   Int
  userId      Int
  title       String
  description String?
  category    String?
  status      String            @default("PENDING")
  progress    Float             @default(0)
  deadline    DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  materialId  Int?
  kpiScores   KPIScore[]
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  material    LearningMaterial? @relation(fields: [materialId], references: [id])
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KnowledgeReview {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  title     String
  score     Float?
  comments  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LearningMaterial {
  id                 Int                 @id @default(autoincrement())
  companyId          Int
  title              String
  content            String
  fileUrl            String?
  category           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  targetDivision     String?
  targetJobTitle     String?
  exams              Exam[]
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  learningObjectives LearningObjective[]
}

model Exam {
  id             Int               @id @default(autoincrement())
  companyId      Int
  materialId     Int?
  title          String
  description    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  targetDivision String?
  targetJobTitle String?
  minScore       Float             @default(70)
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  material       LearningMaterial? @relation(fields: [materialId], references: [id])
  attempts       ExamAttempt[]
  questions      ExamQuestion[]
}

model ExamQuestion {
  id            Int    @id @default(autoincrement())
  examId        Int
  question      String
  options       String
  correctAnswer String
  exam          Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model ExamAttempt {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  examId    Int
  score     Float
  answers   String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id                 Int           @id @default(autoincrement())
  companyId          Int
  invoiceNumber      String        @unique
  month              Int
  year               Int
  amount             Float
  status             InvoiceStatus @default(UNPAID)
  contractType       ContractType
  contractValue      Float
  employeeLimit      Int           @default(0)
  photoRetentionDays Int           @default(30)
  dueDate            DateTime
  paidAt             DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  company            Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, month, year])
}

model GlobalSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id          String        @id @default(uuid())
  visitorName String?
  email       String?
  userId      Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages    ChatMessage[]
  user        User?         @relation(fields: [userId], references: [id])
}

model ChatMessage {
  id        Int         @id @default(autoincrement())
  sessionId String
  sender    ChatSender
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Customer {
  id         Int      @id @default(autoincrement())
  companyId  Int
  name       String
  phone      String?
  email      String?
  address    String?
  points     Float    @default(0)
  totalSpent Float    @default(0)
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  updatedAt  DateTime @default(now()) @db.Timestamp(6)
}

model Product {
  id               Int                @id @default(autoincrement())
  companyId        Int
  name             String
  sku              String?            @unique
  description      String?
  price            Float              @default(0)
  costPrice        Float              @default(0)
  stock            Float              @default(0)
  minStock         Float              @default(0)
  unit             String             @default("Pcs")
  categoryId       Int?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  Company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  StockTransaction StockTransaction[]
  WarehouseStock   WarehouseStock[]
}

model ProductRecipe {
  id         Int       @id @default(autoincrement())
  productId  Int
  materialId Int
  quantity   Float
  updatedAt  DateTime? @default(now()) @db.Timestamp(6)
}

model Sale {
  id            Int          @id @default(autoincrement())
  companyId     Int
  invoiceNumber String       @unique
  customerId    Int?
  date          DateTime     @default(now()) @db.Timestamp(6)
  totalAmount   Float        @default(0)
  status        String       @default("PAID")
  accountId     Int?
  notes         String?
  createdAt     DateTime     @default(now()) @db.Timestamp(6)
  updatedAt     DateTime     @default(now()) @db.Timestamp(6)
  SaleItem      SaleItem[]
  SaleReturn    SaleReturn[]

  @@index([companyId, date])
}

model SaleItem {
  id        Int   @id @default(autoincrement())
  saleId    Int
  productId Int
  quantity  Float
  price     Float
  total     Float
  Sale      Sale  @relation(fields: [saleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model SaleReturn {
  id                Int              @id @default(autoincrement())
  companyId         Int
  saleId            Int
  returnNumber      String           @unique
  date              DateTime         @default(now()) @db.Timestamp(6)
  totalRefundAmount Float            @default(0)
  notes             String?
  accountId         Int?
  createdAt         DateTime         @default(now()) @db.Timestamp(6)
  updatedAt         DateTime         @default(now()) @db.Timestamp(6)
  Sale              Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  SaleReturnItem    SaleReturnItem[]
}

model SaleReturnItem {
  id         Int        @id @default(autoincrement())
  returnId   Int
  productId  Int
  quantity   Float
  price      Float
  total      Float
  SaleReturn SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model StockTransaction {
  id        Int      @id @default(autoincrement())
  productId Int
  type      String
  quantity  Float
  reference String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  Product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  warehouseId Int?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
}

model Warehouse {
  id              Int                @id @default(autoincrement())
  companyId       Int
  name            String
  location        String?
  isMain          Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stocks          WarehouseStock[]
  transactions    StockTransaction[]
}

model WarehouseStock {
  id          Int       @id @default(autoincrement())
  productId   Int
  warehouseId Int
  quantity    Float     @default(0)
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
}

enum AppModule {
  ABSENSI
  FINANCE
  BOTH
  INVENTORY
}

enum ExpenseStatus {
  PAID
  PENDING
}

enum ExpenseType {
  OPERATIONAL
  COGS
}

enum OvertimeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  SUPERADMIN
  ADMIN
  EMPLOYEE
  OWNER
  MANAGER
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  ANNUAL
  SICK
}

enum SalaryStatus {
  DRAFT
  PAID
}

enum ContractType {
  LUMSUM
  SATUAN
}

enum AbsenceDeductionType {
  PRO_RATA
  FIXED_AMOUNT
}

enum ReimbursementStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LoanStatus {
  PENDING
  ACTIVE
  COMPLETED
  REJECTED
}

enum InvoiceStatus {
  UNPAID
  PAID
  CANCELLED
}

enum ChatSender {
  USER
  AI
  ADMIN
}
model PeriodClosing {
  id           Int      @id @default(autoincrement())
  companyId    Int
  month        Int
  year         Int
  closedAt     DateTime @default(now())
  closedBy     Int
  totalIncome  Float
  totalExpense Float
  netProfit    Float
  status       String   @default("CLOSED")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, month, year])
}
