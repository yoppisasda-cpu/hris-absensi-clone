generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id                     Int                  @id @default(autoincrement())
  name                   String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  latitude               Float?
  longitude              Float?
  radius                 Int?                 @default(100)
  absenceDeductionRate   Float                @default(0)
  absenceDeductionType   AbsenceDeductionType @default(PRO_RATA)
  integrationApiKey      String?              @unique
  lateDeductionRate      Float                @default(50000)
  sickLeaveDeductionRate Float                @default(0)
  contractEnd            DateTime?
  contractStart          DateTime?
  contractType           ContractType         @default(LUMSUM)
  contractValue          Float                @default(0)
  picName                String?
  picPhone               String?
  employeeLimit          Int                  @default(0)
  photoRetentionDays     Int                  @default(30)
  announcements          Announcement[]
  assets                 Asset[]
  attendances            Attendance[]
  bonuses                Bonus[]
  branches               Branch[]
  documents              EmployeeDocument[]
  employeeVents          EmployeeVent[]
  exams                  Exam[]
  examAttempts           ExamAttempt[]
  holidays               Holiday[]
  invoices               Invoice[]
  kpiIndicators          KPIIndicator[]
  kpiScores              KPIScore[]
  knowledgeReviews       KnowledgeReview[]
  learningMaterials      LearningMaterial[]
  learningObjectives     LearningObjective[]
  leaveRequests          LeaveRequest[]
  loans                  Loan[]
  notifications          Notification[]
  overtimeRequests       OvertimeRequest[]
  payrolls               Payroll[]
  reimbursements         Reimbursement[]
  shifts                 Shift[]
  users                  User[]
}

model Branch {
  id        Int      @id @default(autoincrement())
  companyId Int
  name      String
  latitude  Float?
  longitude Float?
  radius    Int?     @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users     User[]
}

model User {
  id                      Int                 @id @default(autoincrement())
  companyId               Int
  email                   String              @unique
  password                String
  name                    String
  role                    Role                @default(EMPLOYEE)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  basicSalary             Float               @default(0)
  shiftId                 Int?
  allowance               Float               @default(0)
  branchId                Int?
  division                String?
  emailNotifications      Boolean             @default(true)
  grade                   String?
  jobTitle                String?
  joinDate                DateTime?
  overtimeRate            Float               @default(0)
  bpjsKesehatan           Boolean             @default(false)
  bpjsKetenagakerjaan     Boolean             @default(false)
  contractEndDate         DateTime?
  language                String              @default("id")
  reportToId              Int?
  isActive                Boolean             @default(true)
  resignDate              DateTime?
  faceReferenceUrl        String?
  assets                  Asset[]
  attendances             Attendance[]
  bonuses                 Bonus[]
  documents               EmployeeDocument[]
  employeeVents           EmployeeVent[]
  examAttempts            ExamAttempt[]
  kpiScores               KPIScore[]
  knowledgeReviews        KnowledgeReview[]
  learningObjectives      LearningObjective[]
  managedLeaveRequests    LeaveRequest[]      @relation("LeaveApprover")
  leaveRequests           LeaveRequest[]
  loans                   Loan[]
  notifications           Notification[]
  managedOvertimeRequests OvertimeRequest[]   @relation("OvertimeApprover")
  overtimeRequests        OvertimeRequest[]
  payrolls                Payroll[]
  reimbursements          Reimbursement[]
  branch                  Branch?             @relation(fields: [branchId], references: [id])
  company                 Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reportTo                User?               @relation("ReportingLine", fields: [reportToId], references: [id])
  subordinates            User[]              @relation("ReportingLine")
  chatSessions            ChatSession[]
  shift                   Shift?              @relation(fields: [shiftId], references: [id])
}

model OvertimeRequest {
  id            Int            @id @default(autoincrement())
  companyId     Int
  userId        Int
  date          DateTime
  durationHours Float
  reason        String
  status        OvertimeStatus @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  approverId    Int?
  approver      User?          @relation("OvertimeApprover", fields: [approverId], references: [id])
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Shift {
  id        Int      @id @default(autoincrement())
  companyId Int
  title     String
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users     User[]
}

model Attendance {
  id               Int              @id @default(autoincrement())
  companyId        Int
  userId           Int
  clockIn          DateTime         @default(now())
  clockOut         DateTime?
  lat              Float?
  lng              Float?
  photoUrl         String?
  status           AttendanceStatus @default(PRESENT)
  mood             String?
  moodScore        Float?
  clockOutLat      Float?
  clockOutLng      Float?
  clockOutPhotoUrl String?
  faceSimilarityScore Float?
  isFaceVerified     Boolean          @default(false)
  company          Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id         Int         @id @default(autoincrement())
  companyId  Int
  userId     Int
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     LeaveStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  type       LeaveType   @default(ANNUAL)
  approverId Int?
  approver   User?       @relation("LeaveApprover", fields: [approverId], references: [id])
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payroll {
  id                           Int          @id @default(autoincrement())
  companyId                    Int
  userId                       Int
  month                        Int
  year                         Int
  basicSalary                  Float
  attendanceCount              Int
  lateCount                    Int
  deductions                   Float
  netSalary                    Float
  status                       SalaryStatus @default(DRAFT)
  createdAt                    DateTime     @default(now())
  updatedAt                    DateTime     @updatedAt
  allowance                    Float        @default(0)
  loanDeduction                Float        @default(0)
  overtimeHours                Float        @default(0)
  overtimePay                  Float        @default(0)
  bpjsKesehatanDeduction       Float        @default(0)
  bpjsKetenagakerjaanDeduction Float        @default(0)
  sickLeaveCount               Int          @default(0)
  sickLeaveDeduction           Float        @default(0)
  reimbursementPay             Float        @default(0)
  bonusPay                     Float        @default(0)
  company                      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

model Loan {
  id               Int        @id @default(autoincrement())
  companyId        Int
  userId           Int
  amount           Float
  monthlyDeduction Float
  remainingAmount  Float
  status           LoanStatus @default(PENDING)
  description      String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  company          Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reimbursement {
  id          Int                 @id @default(autoincrement())
  companyId   Int
  userId      Int
  title       String
  description String?
  amount      Float
  receiptUrl  String?
  status      ReimbursementStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  fraudReason String?
  isFraud     Boolean             @default(false)
  ocrAmount   Float?
  ocrCategory String?
  ocrDate     DateTime?
  receiptHash String?
  isPaid      Boolean             @default(false)
  paidAt      DateTime?
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Holiday {
  id        Int       @id @default(autoincrement())
  companyId Int
  date      DateTime
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  endDate   DateTime?
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
}

model Announcement {
  id         Int      @id @default(autoincrement())
  companyId  Int
  title      String
  content    String
  isPriority Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  imageUrl   String?
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmployeeDocument {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  title     String
  fileUrl   String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id           Int       @id @default(autoincrement())
  companyId    Int
  userId       Int?
  name         String
  serialNumber String
  condition    String    @default("GOOD")
  purchaseDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  imageUrl     String?
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User?     @relation(fields: [userId], references: [id])

  @@unique([companyId, serialNumber])
}

model Bonus {
  id          Int      @id @default(autoincrement())
  companyId   Int
  userId      Int
  type        String
  amount      Float
  description String?
  month       Int
  year        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KPIIndicator {
  id          Int        @id @default(autoincrement())
  companyId   Int
  name        String
  description String?
  target      Float      @default(100)
  weight      Float      @default(1)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  isSystem    Boolean    @default(false)
  systemType  String?
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  scores      KPIScore[]
}

model KPIScore {
  id          Int          @id @default(autoincrement())
  companyId   Int
  userId      Int
  indicatorId Int
  score       Float
  comment     String?
  month       Int
  year        Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  indicator   KPIIndicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, indicatorId, month, year])
}

model EmployeeVent {
  id          Int      @id @default(autoincrement())
  companyId   Int
  userId      Int?
  content     String
  isAnonymous Boolean  @default(false)
  sentiment   String?
  mood        String?
  score       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])
}

model LearningObjective {
  id          Int       @id @default(autoincrement())
  companyId   Int
  userId      Int
  title       String
  description String?
  category    String?
  status      String    @default("PENDING")
  progress    Float     @default(0)
  deadline    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KnowledgeReview {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  title     String
  score     Float?
  comments  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LearningMaterial {
  id             Int      @id @default(autoincrement())
  companyId      Int
  title          String
  content        String
  fileUrl        String?
  category       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  targetDivision String?
  targetJobTitle String?
  exams          Exam[]
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Exam {
  id             Int               @id @default(autoincrement())
  companyId      Int
  materialId     Int?
  title          String
  description    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  targetDivision String?
  targetJobTitle String?
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  material       LearningMaterial? @relation(fields: [materialId], references: [id])
  attempts       ExamAttempt[]
  questions      ExamQuestion[]
}

model ExamQuestion {
  id            Int    @id @default(autoincrement())
  examId        Int
  question      String
  options       String
  correctAnswer String
  exam          Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model ExamAttempt {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  examId    Int
  score     Float
  answers   String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            Int           @id @default(autoincrement())
  companyId     Int
  invoiceNumber String        @unique
  month         Int
  year          Int
  amount        Float
  status        InvoiceStatus @default(UNPAID)
  contractType  ContractType
  contractValue Float
  employeeLimit Int           @default(0)
  photoRetentionDays Int      @default(30)
  dueDate       DateTime
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, month, year])
}

model GlobalSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OvertimeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  SUPERADMIN
  ADMIN
  EMPLOYEE
  MANAGER
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  ANNUAL
  SICK
}

enum SalaryStatus {
  DRAFT
  PAID
}

enum ContractType {
  LUMSUM
  SATUAN
}

enum AbsenceDeductionType {
  PRO_RATA
  FIXED_AMOUNT
}

enum ReimbursementStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LoanStatus {
  PENDING
  ACTIVE
  COMPLETED
  REJECTED
}

enum InvoiceStatus {
  UNPAID
  PAID
  CANCELLED
}

model ChatSession {
  id          String        @id @default(uuid())
  visitorName String?
  email       String?
  userId      Int?          // If a logged in user is chatting
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages    ChatMessage[]
  user        User?         @relation(fields: [userId], references: [id])
}

model ChatMessage {
  id        Int          @id @default(autoincrement())
  sessionId String
  sender    ChatSender
  content   String
  createdAt DateTime     @default(now())
  session   ChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum ChatSender {
  USER
  AI
  ADMIN
}
