generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id                     Int                  @id @default(autoincrement())
  name                   String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  latitude               Float?
  longitude              Float?
  radius                 Int?                 @default(100)
  absenceDeductionRate   Float                @default(0)
  absenceDeductionType   AbsenceDeductionType @default(PRO_RATA)
  integrationApiKey      String?              @unique
  lateDeductionRate      Float                @default(50000)
  sickLeaveDeductionRate Float                @default(0)
  contractEnd            DateTime?
  contractStart          DateTime?
  contractType           ContractType         @default(BULANAN)
  contractValue          Float                @default(0)
  picName                String?
  picPhone               String?
  employeeLimit          Int                  @default(0)
  adminLimit             Int                  @default(2)
  posLimit               Int                  @default(1)
  photoRetentionDays     Int                  @default(30)
  modules                AppModule            @default(ABSENSI)
  address                String?
  logoUrl                String?
  lateGracePeriod        Int                  @default(0)
  timezone               String               @default("Asia/Jakarta")
  workDaysPerMonth       Int                  @default(25)
  purchasedInsights      String[]             @default([])
  addons                 String[]             @default([])
  plan                   SubscriptionPlan     @default(STARTER)
  isApiEnabled           Boolean              @default(false)
  authorizedCapital      Float                @default(0)
  discountKpi            Int                  @default(0)
  discountLearning       Int                  @default(0)
  discountInventory      Int                  @default(0)
  discountAi             Int                  @default(0)
  discountFraud          Int                  @default(0)
  discountExpansion      Int                  @default(0)
  discountProspecting    Int                  @default(0)
  crmEnabled             Boolean              @default(true)
  isActive               Boolean              @default(true)
  waGatewayUrl           String?              // URL Wablas (misal: https://solo.wablas.com)
  waApiKey               String?              // Token API Wablas
  waProspectTemplate     String?              // Template pesan broadcast prospek
  memberDiscountType     String?              @default("PERCENTAGE")
  memberDiscountValue    Float                @default(0)
  pointsEarnRatio        Float                @default(0)
  pointsRedeemValue      Float                @default(0)
  vouchers               Voucher[]
  announcements          Announcement[]
  assets                 Asset[]
  assignments            Assignment[]
  attendances            Attendance[]
  bonuses                Bonus[]
  branches               Branch[]
  customizationGroups    CustomizationGroup[]
  dividends              Dividend[]
  documents              EmployeeDocument[]
  employeeVents          EmployeeVent[]
  exams                  Exam[]
  examAttempts           ExamAttempt[]
  expenses               Expense[]
  expenseCategories      ExpenseCategory[]
  financialAccounts      FinancialAccount[]
  holidays               Holiday[]
  incomes                Income[]
  incomeCategories       IncomeCategory[]
  integrationRequests    IntegrationRequest[]
  invoices               Invoice[]
  kpiIndicators          KPIIndicator[]
  kpiScores              KPIScore[]
  knowledgeReviews       KnowledgeReview[]
  learningMaterials      LearningMaterial[]
  learningObjectives     LearningObjective[]
  leaveRequests          LeaveRequest[]
  loans                  Loan[]
  notifications          Notification[]
  overtimeRequests       OvertimeRequest[]
  payrolls               Payroll[]
  periodClosings         PeriodClosing[]
  posClosings            PosClosing[]
  Product                Product[]
  productCategories      ProductCategory[]
  purchaseOrders         PurchaseOrder[]
  reimbursements         Reimbursement[]
  salesOrders            SalesOrder[]
  shareholders           Shareholder[]
  shifts                 Shift[]
  shiftSchedules         ShiftSchedule[]
  transfers              Transfer[]
  users                  User[]
  userAccess             UserAccess[]
  warehouses             Warehouse[]
  prospects             Prospect[]
  chatSessions          ChatSession[]
}

model FinancialAccount {
  id            Int        @id @default(autoincrement())
  companyId     Int
  name          String
  type          String
  balance       Float      @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  branchId      Int?
  dividends     Dividend[]
  expenses      Expense[]
  branch        Branch?    @relation(fields: [branchId], references: [id])
  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  incomes       Income[]
  fromTransfers Transfer[] @relation("FromAccount")
  toTransfers   Transfer[] @relation("ToAccount")
}

model IncomeCategory {
  id        Int      @id @default(autoincrement())
  companyId Int
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  incomes   Income[]
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
}

model Income {
  id           Int              @id @default(autoincrement())
  companyId    Int
  accountId    Int
  categoryId   Int
  amount       Float
  date         DateTime         @default(now())
  description  String?
  receivedFrom String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  branchId     Int?
  account      FinancialAccount @relation(fields: [accountId], references: [id])
  branch       Branch?          @relation(fields: [branchId], references: [id])
  category     IncomeCategory   @relation(fields: [categoryId], references: [id])
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, date])
  @@index([companyId, branchId])
}

model ExpenseCategory {
  id        Int         @id @default(autoincrement())
  companyId Int
  name      String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  type      ExpenseType @default(OPERATIONAL)
  expenses  Expense[]
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
}

model Expense {
  id          Int               @id @default(autoincrement())
  companyId   Int
  accountId   Int?
  categoryId  Int
  amount      Float
  date        DateTime          @default(now())
  description String?
  paidTo      String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  dueDate     DateTime?
  status      ExpenseStatus     @default(PAID)
  supplierId  Int?
  productId   Int?
  quantity    Float?            @default(0)
  branchId    Int?
  account     FinancialAccount? @relation(fields: [accountId], references: [id])
  branch      Branch?           @relation(fields: [branchId], references: [id])
  category    ExpenseCategory   @relation(fields: [categoryId], references: [id])
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product     Product?          @relation(fields: [productId], references: [id])
  supplier    Supplier?         @relation(fields: [supplierId], references: [id], onUpdate: NoAction)

  @@index([companyId, date])
  @@index([companyId, branchId])
}

model Supplier {
  id             Int             @id @default(autoincrement())
  companyId      Int
  name           String
  contactPerson  String?
  phone          String?
  email          String?
  address        String?
  category       String?
  createdAt      DateTime        @default(now()) @db.Timestamp(6)
  updatedAt      DateTime        @default(now()) @updatedAt @db.Timestamp(6)
  expenses          Expense[]
  purchaseOrders    PurchaseOrder[]
  stockTransactions StockTransaction[]
}

model Branch {
  id         Int                @id @default(autoincrement())
  companyId  Int
  name       String
  latitude   Float?
  longitude  Float?
  radius     Int?               @default(100)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  company    Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses   Expense[]
  accounts   FinancialAccount[]
  incomes    Income[]
  sales      Sale[]
  users      User[]
  warehouses Warehouse[]
}

model User {
  id                      Int                 @id @default(autoincrement())
  companyId               Int
  email                   String              @unique
  password                String
  name                    String
  role                    Role                @default(EMPLOYEE)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  basicSalary             Float               @default(0)
  shiftId                 Int?
  allowance               Float               @default(0)
  branchId                Int?
  division                String?
  emailNotifications      Boolean             @default(true)
  grade                   String?
  jobTitle                String?
  joinDate                DateTime?
  overtimeRate            Float               @default(0)
  mealAllowance           Float               @default(0)
  bpjsKesehatan           Boolean             @default(false)
  bpjsKetenagakerjaan     Boolean             @default(false)
  contractEndDate         DateTime?
  language                String              @default("id")
  faceReferenceUrl        String?
  isActive                Boolean             @default(true)
  reportToId              Int?
  resignDate              DateTime?
  lastDeviceId            String?
  taxStatus               String              @default("TK-0")
  assets                  Asset[]
  createdAssignments      Assignment[]        @relation("AssignmentCreator")
  assignments             Assignment[]        @relation("AssignmentUser")
  attendances             Attendance[]
  bonuses                 Bonus[]
  chatSessions            ChatSession[]
  documents               EmployeeDocument[]
  employeeVents           EmployeeVent[]
  examAttempts            ExamAttempt[]
  kpiScores               KPIScore[]
  knowledgeReviews        KnowledgeReview[]
  learningObjectives      LearningObjective[]
  managedLeaveRequests    LeaveRequest[]      @relation("LeaveApprover")
  leaveRequests           LeaveRequest[]
  loans                   Loan[]
  notifications           Notification[]
  managedOvertimeRequests OvertimeRequest[]   @relation("OvertimeApprover")
  overtimeRequests        OvertimeRequest[]
  payrolls                Payroll[]
  pendingBills            PendingBill[]
  posClosings             PosClosing[]
  poApprovedBy            PurchaseOrder[]     @relation("POApprovedBy")
  poCreatedBy             PurchaseOrder[]     @relation("POCreatedBy")
  reimbursements          Reimbursement[]
  sales                   Sale[]
  shiftSchedules          ShiftSchedule[]
  branch                  Branch?             @relation(fields: [branchId], references: [id])
  company                 Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reportTo                User?               @relation("ReportingLine", fields: [reportToId], references: [id])
  subordinates            User[]              @relation("ReportingLine")
  shift                   Shift?              @relation(fields: [shiftId], references: [id])
  accessibleCompanies     UserAccess[]
}

model UserAccess {
  id        Int      @id @default(autoincrement())
  userId    Int
  companyId Int
  role      Role     @default(OWNER)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model OvertimeRequest {
  id            Int            @id @default(autoincrement())
  companyId     Int
  userId        Int
  date          DateTime
  durationHours Float
  reason        String
  status        OvertimeStatus @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  approverId    Int?
  approver      User?          @relation("OvertimeApprover", fields: [approverId], references: [id])
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Shift {
  id             Int             @id @default(autoincrement())
  companyId      Int
  title          String
  startTime      String
  endTime        String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shiftSchedules ShiftSchedule[]
  users          User[]
}

model ShiftSchedule {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  shiftId   Int?
  isOff     Boolean  @default(false)
  date      DateTime @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shift     Shift?   @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Attendance {
  id                   Int              @id @default(autoincrement())
  companyId            Int
  userId               Int
  clockIn              DateTime         @default(now())
  clockOut             DateTime?
  lat                  Float?
  lng                  Float?
  photoUrl             String?
  status               AttendanceStatus @default(PRESENT)
  mood                 String?
  moodScore            Float?
  clockOutLat          Float?
  clockOutLng          Float?
  clockOutPhotoUrl     String?
  faceSimilarityScore  Float?
  isFaceVerified       Boolean          @default(false)
  deviceId             String?
  fraudScore           Float?
  isSuspicious         Boolean          @default(false)
  lateMinutes          Int?             @default(0)
  earlyCheckOutMinutes Int?             @default(0)
  company              Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, clockIn])
}

model LeaveRequest {
  id         Int         @id @default(autoincrement())
  companyId  Int
  userId     Int
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     LeaveStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  type       LeaveType   @default(ANNUAL)
  approverId Int?
  approver   User?       @relation("LeaveApprover", fields: [approverId], references: [id])
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payroll {
  id                           Int          @id @default(autoincrement())
  companyId                    Int
  userId                       Int
  month                        Int
  year                         Int
  basicSalary                  Float
  attendanceCount              Int
  lateCount                    Int
  deductions                   Float
  netSalary                    Float
  status                       SalaryStatus @default(DRAFT)
  createdAt                    DateTime     @default(now())
  updatedAt                    DateTime     @updatedAt
  allowance                    Float        @default(0)
  mealAllowance                Float        @default(0)
  loanDeduction                Float        @default(0)
  overtimeHours                Float        @default(0)
  overtimePay                  Float        @default(0)
  bpjsKesehatanDeduction       Float        @default(0)
  bpjsKetenagakerjaanDeduction Float        @default(0)
  sickLeaveCount               Int          @default(0)
  sickLeaveDeduction           Float        @default(0)
  reimbursementPay             Float        @default(0)
  bonusPay                     Float        @default(0)
  bpjsCompanyContribution      Float        @default(0)
  pph21Deduction               Float        @default(0)
  company                      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

model Loan {
  id               Int        @id @default(autoincrement())
  companyId        Int
  userId           Int
  amount           Float
  monthlyDeduction Float
  remainingAmount  Float
  status           LoanStatus @default(PENDING)
  description      String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  company          Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reimbursement {
  id          Int                 @id @default(autoincrement())
  companyId   Int
  userId      Int
  title       String
  description String?
  amount      Float
  receiptUrl  String?
  status      ReimbursementStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  fraudReason String?
  isFraud     Boolean             @default(false)
  ocrAmount   Float?
  ocrCategory String?
  ocrDate     DateTime?
  receiptHash String?
  isPaid      Boolean             @default(false)
  paidAt      DateTime?
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Holiday {
  id        Int       @id @default(autoincrement())
  companyId Int
  date      DateTime
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  endDate   DateTime?
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
}

model Announcement {
  id         Int      @id @default(autoincrement())
  companyId  Int
  title      String
  content    String
  isPriority Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  imageUrl   String?
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmployeeDocument {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  title     String
  fileUrl   String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id             Int       @id @default(autoincrement())
  companyId      Int
  userId         Int?
  name           String
  category       String    @default("ELECTRONIC")
  taxCategory    String?   @default("NON_TAXABLE")
  serialNumber   String?
  condition      String    @default("GOOD")
  purchaseDate   DateTime?
  purchasePrice  Float?    @default(0)
  residualValue  Float?    @default(0)
  usefulLife     Int?      @default(0)
  isDepreciating Boolean?  @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  imageUrl       String?
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user           User?     @relation(fields: [userId], references: [id])

  @@index([companyId, serialNumber])
}

model Bonus {
  id          Int      @id @default(autoincrement())
  companyId   Int
  userId      Int
  type        String
  amount      Float
  description String?
  month       Int
  year        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KPIIndicator {
  id          Int        @id @default(autoincrement())
  companyId   Int
  name        String
  description String?
  target      Float      @default(100)
  weight      Float      @default(1)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  isSystem    Boolean    @default(false)
  systemType  String?
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  scores      KPIScore[]
}

model KPIScore {
  id                  Int                @id @default(autoincrement())
  companyId           Int
  userId              Int
  indicatorId         Int
  score               Float
  comment             String?
  month               Int
  year                Int
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  learningObjectiveId Int?
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  indicator           KPIIndicator       @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  learningObjective   LearningObjective? @relation(fields: [learningObjectiveId], references: [id])
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, indicatorId, month, year])
}

model EmployeeVent {
  id          Int      @id @default(autoincrement())
  companyId   Int
  userId      Int?
  content     String
  isAnonymous Boolean  @default(false)
  sentiment   String?
  mood        String?
  score       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])
}

model LearningObjective {
  id          Int               @id @default(autoincrement())
  companyId   Int
  userId      Int
  title       String
  description String?
  category    String?
  status      String            @default("PENDING")
  progress    Float             @default(0)
  deadline    DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  materialId  Int?
  kpiScores   KPIScore[]
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  material    LearningMaterial? @relation(fields: [materialId], references: [id])
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KnowledgeReview {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  title     String
  score     Float?
  comments  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LearningMaterial {
  id                 Int                 @id @default(autoincrement())
  companyId          Int
  title              String
  content            String
  fileUrl            String?
  category           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  targetDivision     String?
  targetJobTitle     String?
  exams              Exam[]
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  learningObjectives LearningObjective[]
}

model Exam {
  id             Int               @id @default(autoincrement())
  companyId      Int
  materialId     Int?
  title          String
  description    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  targetDivision String?
  targetJobTitle String?
  minScore       Float             @default(70)
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  material       LearningMaterial? @relation(fields: [materialId], references: [id])
  attempts       ExamAttempt[]
  questions      ExamQuestion[]
}

model ExamQuestion {
  id            Int    @id @default(autoincrement())
  examId        Int
  question      String
  options       String
  correctAnswer String
  exam          Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model ExamAttempt {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  examId    Int
  score     Float
  answers   String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id                 Int           @id @default(autoincrement())
  companyId          Int
  invoiceNumber      String        @unique
  month              Int
  year               Int
  amount             Float
  status             InvoiceStatus @default(UNPAID)
  contractType       ContractType
  contractValue      Float
  employeeLimit      Int           @default(10)
  adminLimit         Int           @default(2)
  photoRetentionDays Int?          @default(30)
  dueDate            DateTime
  paidAt             DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  company            Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, month, year])
}

model GlobalSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id          String        @id @default(uuid())
  companyId   Int?          @default(1)
  visitorName String?
  email       String?
  phone       String?
  userId      Int?
  isWhatsApp  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages    ChatMessage[]
  user        User?         @relation(fields: [userId], references: [id])
  company     Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        Int         @id @default(autoincrement())
  sessionId String
  sender    ChatSender
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Customer {
  id          Int          @id @default(autoincrement())
  companyId   Int
  name        String
  phone       String?
  email       String?
  address     String?
  points      Float        @default(0)
  totalSpent  Float        @default(0)
  createdAt   DateTime     @default(now()) @db.Timestamp(6)
  updatedAt   DateTime     @default(now()) @db.Timestamp(6)
  salesOrders SalesOrder[]
  isMember    Boolean      @default(false)
  birthDate   DateTime?
  gender      String?      // L/P

  @@unique([companyId, phone], name: "companyId_phone")
}

model ProductCategory {
  id        Int       @id @default(autoincrement())
  companyId Int
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Product {
  id                 Int                    @id @default(autoincrement())
  companyId          Int
  name               String
  sku                String?                @unique
  description        String?
  price              Float                  @default(0)
  costPrice          Float                  @default(0)
  stock              Float                  @default(0)
  minStock           Float                  @default(0)
  categoryId         Int?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime
  unit               String                 @default("Pcs")
  showInPos          Boolean                @default(true)
  type               ProductType            @default(FINISHED_GOOD)
  trackStock         Boolean                @default(true)
  priceGofood        Float                  @default(0)
  priceGrabfood      Float                  @default(0)
  priceShopeefood    Float                  @default(0)
  recipeYield        Float                  @default(1)
  expenses           Expense[]
  category           ProductCategory?       @relation(fields: [categoryId], references: [id])
  Company            Company                @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  customizations     ProductCustomization[]
  UsedInRecipes      ProductRecipe[]        @relation("MaterialRecipes")
  Recipes            ProductRecipe[]        @relation("ProductRecipes")
  purchaseOrderItems PurchaseOrderItem[]
  salesOrderItems    SalesOrderItem[]
  StockTransaction   StockTransaction[]
  WarehouseStock     WarehouseStock[]
}

model ProductRecipe {
  id         Int       @id @default(autoincrement())
  productId  Int
  materialId Int
  quantity   Float
  updatedAt  DateTime? @default(now()) @db.Timestamp(6)
  Material   Product   @relation("MaterialRecipes", fields: [materialId], references: [id], onDelete: Cascade)
  Product    Product   @relation("ProductRecipes", fields: [productId], references: [id], onDelete: Cascade)
}

model Sale {
  id               Int          @id @default(autoincrement())
  companyId        Int
  branchId         Int?
  invoiceNumber    String       @unique
  customerId       Int?
  customerName     String?
  customerPhone    String?
  date             DateTime     @default(now()) @db.Timestamp(6)
  totalAmount      Float        @default(0)
  status           String       @default("PAID")
  saleType         String       @default("WALK_IN")
  serviceFee       Float        @default(0)
  markupPercentage Float        @default(0)
  totalCommission  Float        @default(0)
  accountId        Int?
  notes            String?
  createdAt        DateTime     @default(now()) @db.Timestamp(6)
  updatedAt        DateTime     @default(now()) @db.Timestamp(6)
  cashierId        Int?
  isTukarFaktur    Boolean      @default(false)
  tukarFakturDate  DateTime?
  tukarFakturRef   String?
  memberDiscountAmount   Float        @default(0)
  voucherCode            String?
  voucherDiscountAmount  Float        @default(0)
  pointsUsed             Float        @default(0)
  pointsEarned           Float        @default(0)
  branch           Branch?      @relation(fields: [branchId], references: [id])
  cashier          User?        @relation(fields: [cashierId], references: [id])
  SaleItem         SaleItem[]
  SaleReturn       SaleReturn[]

  @@index([companyId, date])
  @@index([companyId, branchId])
}

model SaleItem {
  id            Int   @id @default(autoincrement())
  saleId        Int
  productId     Int
  quantity      Float
  price         Float
  originalPrice Float @default(0)
  total         Float
  modifiers     Json?
  Sale          Sale  @relation(fields: [saleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model SaleReturn {
  id                Int              @id @default(autoincrement())
  companyId         Int
  saleId            Int
  returnNumber      String           @unique
  date              DateTime         @default(now()) @db.Timestamp(6)
  totalRefundAmount Float            @default(0)
  notes             String?
  accountId         Int?
  createdAt         DateTime         @default(now()) @db.Timestamp(6)
  updatedAt         DateTime         @default(now()) @db.Timestamp(6)
  Sale              Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  SaleReturnItem    SaleReturnItem[]
}

model SaleReturnItem {
  id         Int        @id @default(autoincrement())
  returnId   Int
  productId  Int
  quantity   Float
  price      Float
  total      Float
  SaleReturn SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model StockTransaction {
  id          Int        @id @default(autoincrement())
  productId   Int
  type        String
  quantity    Float
  reference   String?
  date        DateTime   @default(now())
  createdAt   DateTime   @default(now())
  warehouseId Int?
  supplierId  Int?
  Product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  supplier    Supplier?  @relation(fields: [supplierId], references: [id])
}

model Warehouse {
  id             Int                @id @default(autoincrement())
  companyId      Int
  name           String
  location       String?
  isMain         Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  branchId       Int?
  type           WarehouseType      @default(STORE)
  purchaseOrders PurchaseOrder[]
  transactions   StockTransaction[]
  branch         Branch?            @relation(fields: [branchId], references: [id])
  company        Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stocks         WarehouseStock[]
}

model WarehouseStock {
  id          Int       @id @default(autoincrement())
  productId   Int
  warehouseId Int
  quantity    Float     @default(0)
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
}

model PeriodClosing {
  id           Int      @id @default(autoincrement())
  companyId    Int
  month        Int
  year         Int
  closedAt     DateTime @default(now())
  closedBy     Int
  totalIncome  Float
  totalExpense Float
  netProfit    Float
  status       String   @default("CLOSED")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, month, year])
}

model PendingBill {
  id        Int      @id @default(autoincrement())
  companyId Int
  branchId  Int
  cashierId Int
  label     String?
  items     Json
  saleType  String   @default("WALK_IN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [cashierId], references: [id])
}

model PosClosing {
  id                Int      @id @default(autoincrement())
  companyId         Int
  branchId          Int
  cashierId         Int
  date              DateTime @default(now()) @db.Date
  startTime         DateTime
  endTime           DateTime @default(now())
  totalGrossSales   Float    @default(0)
  totalNetSales     Float    @default(0)
  totalCommission   Float    @default(0)
  totalTransactions Int      @default(0)
  actualCash        Float    @default(0)
  expectedCash      Float    @default(0)
  cashDifference    Float    @default(0)
  notes             String?
  status            String   @default("COMPLETED")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  cashier           User     @relation(fields: [cashierId], references: [id])
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, branchId, date])
  @@index([companyId, date])
}

model Transfer {
  id            Int              @id @default(autoincrement())
  companyId     Int
  fromAccountId Int
  toAccountId   Int
  amount        Float
  date          DateTime         @default(now())
  description   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromAccount   FinancialAccount @relation("FromAccount", fields: [fromAccountId], references: [id])
  toAccount     FinancialAccount @relation("ToAccount", fields: [toAccountId], references: [id])

  @@index([companyId, date])
}

model CustomizationGroup {
  id            Int                    @id @default(autoincrement())
  companyId     Int
  name          String
  isRequired    Boolean                @default(false)
  minSelections Int                    @default(0)
  maxSelections Int                    @default(1)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  company       Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  options       CustomizationOption[]
  products      ProductCustomization[]
}

model CustomizationOption {
  id      Int                @id @default(autoincrement())
  groupId Int
  name    String
  price   Float              @default(0)
  group   CustomizationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model ProductCustomization {
  productId Int
  groupId   Int
  Group     CustomizationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  Product   Product            @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, groupId])
}

model PurchaseOrder {
  id           Int                 @id @default(autoincrement())
  companyId    Int
  supplierId   Int
  orderNumber  String              @unique
  date         DateTime            @default(now())
  totalAmount  Float               @default(0)
  status       POStatus            @default(PENDING)
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  createdById  Int
  approvedById Int?
  warehouseId  Int?
  approvedBy   User?               @relation("POApprovedBy", fields: [approvedById], references: [id])
  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User                @relation("POCreatedBy", fields: [createdById], references: [id])
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  warehouse    Warehouse?          @relation(fields: [warehouseId], references: [id])
  items        PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int
  productId       Int
  quantity        Float
  price           Float
  total           Float
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model IntegrationRequest {
  id        Int           @id @default(autoincrement())
  companyId Int
  status    RequestStatus @default(PENDING)
  note      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model SalesOrder {
  id          Int              @id @default(autoincrement())
  companyId   Int
  customerId  Int
  orderNumber String           @unique
  date        DateTime         @default(now())
  totalAmount Float            @default(0)
  status      SOStatus         @default(PENDING)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  saleId      Int?             @unique
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer    Customer         @relation(fields: [customerId], references: [id])
  items       SalesOrderItem[]
}

model SalesOrderItem {
  id           Int        @id @default(autoincrement())
  salesOrderId Int
  productId    Int
  quantity     Float
  price        Float
  total        Float
  product      Product    @relation(fields: [productId], references: [id])
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
}

model Shareholder {
  id              Int        @id @default(autoincrement())
  companyId       Int
  name            String
  idNumber        String?
  sharePercentage Float
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  dividends       Dividend[]
  company         Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Dividend {
  id                Int               @id @default(autoincrement())
  companyId         Int
  shareholderId     Int
  amount            Float
  date              DateTime          @default(now())
  description       String?
  paidFromAccountId Int?
  status            String            @default("PAID")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  account           FinancialAccount? @relation(fields: [paidFromAccountId], references: [id])
  shareholder       Shareholder       @relation(fields: [shareholderId], references: [id], onDelete: Cascade)
}

model Assignment {
  id             Int              @id @default(autoincrement())
  companyId      Int
  userId         Int
  assignedById   Int
  title          String
  description    String?
  status         AssignmentStatus @default(PENDING)
  priority       String           @default("MEDIUM")
  dueDate        DateTime?
  resultNote     String?
  resultImageUrl String?
  kpiScoreId     Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  assignedBy     User             @relation("AssignmentCreator", fields: [assignedById], references: [id], onDelete: Cascade)
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user           User             @relation("AssignmentUser", fields: [userId], references: [id], onDelete: Cascade)
}

enum AppModule {
  ABSENSI
  FINANCE
  BOTH
  INVENTORY
  POS
}

enum SubscriptionPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum ExpenseStatus {
  PAID
  PENDING
}

enum ExpenseType {
  OPERATIONAL
  COGS
}

enum OvertimeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  SUPERADMIN
  ADMIN
  EMPLOYEE
  OWNER
  MANAGER
  CASHIER
  PURCHASING
  FINANCE
  OPERATIONAL
  POS_VIEWER
  SUPERVISOR
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  ANNUAL
  SICK
}

enum SalaryStatus {
  DRAFT
  PAID
}

enum ContractType {
  BULANAN
  TAHUNAN
}

model OtpVerification {
  id        Int      @id @default(autoincrement())
  companyId Int
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([companyId, phone])
}

enum AbsenceDeductionType {
  PRO_RATA
  FIXED_AMOUNT
}

enum ReimbursementStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LoanStatus {
  PENDING
  ACTIVE
  COMPLETED
  REJECTED
}

enum InvoiceStatus {
  UNPAID
  PAID
  CANCELLED
}

enum ChatSender {
  USER
  ADMIN
  VISITOR
  AI
}

model Prospect {
  id          Int            @id @default(autoincrement())
  companyId   Int
  name        String
  phone       String?
  email       String?
  address     String?
  category    String?
  website     String?
  instagram   String?
  status      ProspectStatus @default(NEW)
  aiScore     Float?
  latitude    Float?
  longitude   Float?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
}

enum ProspectStatus {
  NEW
  CONTACTED
  RESPONDED
  NO_RESPONSE
  INTERESTED
  DEAL
  REJECTED
}

model Voucher {
  id            Int       @id @default(autoincrement())
  companyId     Int
  code          String
  discountType  String    @default("PERCENTAGE")
  discountValue Float
  minPurchase   Float     @default(0)
  maxDiscount   Float?
  validFrom     DateTime?
  validUntil    DateTime?
  quota         Int       @default(0)
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
}

enum WarehouseType {
  STORE
  WAREHOUSE
}

enum ProductType {
  RAW_MATERIAL
  WIP
  FINISHED_GOOD
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum POStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SOStatus {
  PENDING
  APPROVED
  PREPARING
  SHIPPED
  INVOICED
  CANCELLED
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
}
